  <!-- Floating editor toggle -->
  <div class="editBar"><button id="editToggle">✏️ 편집</button></div>

  <script>
    // Simple content store using localStorage
    const KEY = 'softnote_inline_edits_v1';
    const store = JSON.parse(localStorage.getItem(KEY) || '{}');
    const $ = (sel,root=document)=>root.querySelector(sel);
    const $$ = (sel,root=document)=>Array.from(root.querySelectorAll(sel));

    // Restore saved edits
    $$('.editable').forEach(el=>{ const k = el.dataset.key; if(store[k]) el.innerHTML = store[k]; });

    // Toggle edit mode
    const body = document.body; const btn = $('#editToggle');
    let editing = false;
    btn.addEventListener('click',()=>{
      editing = !editing; body.classList.toggle('editing', editing);
      btn.textContent = editing ? '✅ 저장 종료' : '✏️ 편집';
      $$('.editable').forEach(el=> el.setAttribute('contenteditable', editing));
      if(!editing){ localStorage.setItem(KEY, JSON.stringify(store)); alert('저장되었습니다'); }
    });



    // Save on blur/input
    document.addEventListener('input',e=>{
      if(!editing) return; const el = e.target.closest('.editable'); if(!el) return; store[el.dataset.key] = el.innerHTML;
    });
  </script>
